# =============================================================================
# registry — environment variable reference (canonical inventory)
# =============================================================================
#
# This file is the deployment-target-neutral spec for every env var the app
# reads. Operators on Kubernetes, AWS ECS/Fargate, AWS Lambda, EC2/systemd,
# Cloud Run, App Runner, Nomad, etc. consume the same env vars — only the
# wiring differs. Helm chart values, Docker Compose, and any per-platform
# config you write should mirror this file.
#
# Conventions:
#   - Required vars have NO default; the app raises on startup if absent.
#   - Optional vars show the shipped default after the `=`.
#   - Defaults here MUST match registry/config.py `Settings`/`from_env`.
#   - Code outside registry/config.py that reads os.environ directly is
#     either consolidated into Settings or tagged `# config: intentional`.
#
# Use: copy to `.env` for local development (gitignored), or use it as the
# reference list when populating a ConfigMap / task-definition / systemd
# EnvironmentFile.

# -----------------------------------------------------------------------------
# Database — REQUIRED
# -----------------------------------------------------------------------------

# Async (asyncpg) connection string. The app process talks to PgBouncer in
# production; migrations talk to Postgres directly.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/registry

# Optional separate URL for the runtime app -> PgBouncer path. Defaults to
# DATABASE_URL when unset.
# PGBOUNCER_URL=postgresql+asyncpg://user:password@pgbouncer:6432/registry

# Optional URL used by APScheduler's SQLAlchemyJobStore for durable job rows.
# Defaults to DATABASE_URL. When SCHEDULER_USE_MEMORY_JOBSTORE=true this is
# ignored (jobs are in-process and lost on restart).
# SCHEDULER_JOBSTORE_URL=postgresql+asyncpg://user:password@host:5432/registry

# Fall back to APScheduler's MemoryJobStore (no DB persistence). Set to
# "true" / "1" / "yes" for local dev when you don't want job rows in PG.
SCHEDULER_USE_MEMORY_JOBSTORE=false

# -----------------------------------------------------------------------------
# Embedding
# -----------------------------------------------------------------------------

# SentenceTransformer model name. Set to "stub" to skip the download and
# use zero-vector embeddings — only suitable for smoke tests.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Token budget per chunk when splitting fact bodies for embedding.
EMBEDDING_CHUNK_TOKENS=400

# LRU cache size for previously-embedded chunks.
EMBEDDING_CACHE_MAXSIZE=10000

# -----------------------------------------------------------------------------
# Outbox + drain
# -----------------------------------------------------------------------------

# Drain interval (seconds) for the embedding outbox.
OUTBOX_POLL_INTERVAL_S=5

# Max rows claimed per drain pass.
OUTBOX_BATCH_SIZE=32

# Per-row retry ceiling before the outbox row moves to the dead-letter table.
OUTBOX_MAX_ATTEMPTS=5

# Page size for the backfill / reindex scripts.
BACKFILL_BATCH_SIZE=64

# -----------------------------------------------------------------------------
# Webhook delivery
# -----------------------------------------------------------------------------

# Cadence for the WebhookDeliveryWorker drain job. The p95 SLO caps fan-out
# at 30 s; the default 5 s keeps you well inside the SLO with headroom for retries.
WEBHOOK_DRAIN_INTERVAL_S=5

# Per-delivery HTTP timeout (seconds).
WEBHOOK_REQUEST_TIMEOUT_S=10.0

# Max deliveries claimed per drain pass.
WEBHOOK_BATCH_SIZE=50

# -----------------------------------------------------------------------------
# HTTP method routing
# -----------------------------------------------------------------------------

# Which mutation surface to register:
#   rest      — only the standard verb (PATCH / DELETE / etc.). DEFAULT.
#   post_only — only POST-tunneled aliases (POST .../{id}:update etc.).
#   both      — both routes registered. Set this only if you operate behind
#               an enterprise proxy that strips non-GET/POST verbs.
REGISTRY_HTTP_METHODS_MODE=rest

# Separator between resource path and action suffix in the POST-tunneled
# alias. "colon" → /{id}:update; "slash" → /{id}/update.
REGISTRY_HTTP_METHOD_ALIAS_SEPARATOR=colon

# -----------------------------------------------------------------------------
# Auth + OIDC
# -----------------------------------------------------------------------------
#
# The registry accepts credentials via three lanes — pick whichever fits
# the audience:
#
#   1. Identity provider (humans, enterprise SSO). Set OIDC_DISCOVERY_URL
#      to your IdP's discovery document. Works with any provider that
#      implements OpenID Connect (Okta, Azure AD, Auth0, Keycloak,
#      Google Workspace, …). The token must carry `sub` and
#      `tenant_id`/`tid` claims; the matching actor must pre-exist.
#
#   2. API tokens (CI, service accounts, break-glass). Mint with
#      `scripts/mint_token.py --tenant-id … --actor-id … --roles …`.
#      Store the plaintext token wherever your platform stores secrets
#      (Kubernetes Secret, ECS secret ref, systemd EnvironmentFile,
#      AWS Secrets Manager, etc.).
#
#   3. Local development. Run `make dev-token` (idempotent — seeds a
#      tenant + actor + role grants, mints a token, prints it). Add
#      `TOKEN_OUT=.env.dev` to persist `REGISTRY_DEV_TOKEN=...` for reuse.
#
# Both auth lanes (1 and 2) can be active simultaneously. The middleware
# tries OIDC first when the token looks like a JWT and OIDC is configured,
# then falls through to API-token validation on any failure. See
# `docs/auth.md` for the full architecture.

# OIDC discovery URL for JWT-based authentication. Leave unset to disable
# OIDC and accept only opaque bearer tokens from `api_tokens`.
# OIDC_DISCOVERY_URL=https://auth.example.com/.well-known/openid-configuration

# Expected `aud` claim in JWTs issued for this service. When set, OIDC tokens
# whose audience does not match are rejected. Strongly recommended in any
# OIDC-enabled deployment: without it, a JWT issued for a different
# application at the same IdP would be accepted as a valid API token.
# OIDC_EXPECTED_AUDIENCE=

# -----------------------------------------------------------------------------
# Authentication — mode + external claim source
# -----------------------------------------------------------------------------

# Auth mode: "oidc" resolves tenant scope from standard token claims (default).
# "rsam" resolves tenant scope from an external claim source (set
# AUTH_CLAIM_SOURCE_URL when using this mode). Future modes are added here.
AUTH_MODE=oidc

# Base URL of the external claim source. Required when AUTH_MODE != "oidc".
# AUTH_CLAIM_SOURCE_URL=https://entitlements.example.com

# TTL (seconds) for the external claim-source cache. Applies only in modes
# that use an external claim source. 0 disables caching.
AUTH_CLAIM_CACHE_TTL_SECONDS=300

# Maximum staleness (seconds) allowed when the claim source is unreachable
# and AUTH_SERVE_STALE_ON_FAILURE=true. Hard ceiling — never exceed this age.
AUTH_STALE_CEILING_SECONDS=86400

# Serve stale cached claim data when the claim source is unreachable.
# Default false (fail closed). Enable with care — stale entitlements may
# allow or deny access incorrectly during an outage.
AUTH_SERVE_STALE_ON_FAILURE=false

# HTTP header name carrying the per-request tenant identifier.
AUTH_TENANT_ID_HEADER=X-Tenant-ID

# Optional alias header accepted alongside AUTH_TENANT_ID_HEADER. Useful for
# compatibility with clients that send a legacy header name. Leave blank or
# unset to disable the alias.
AUTH_SEAL_ID_HEADER_ALIAS=X-SEAL-ID

# -----------------------------------------------------------------------------
# Progression
# -----------------------------------------------------------------------------

# TTL (seconds) for the cached progression-definition lookup. Short TTL keeps
# the cache fresh after operator edits. 0 disables caching entirely.
PROGRESSION_DEFINITION_CACHE_TTL_SECONDS=60

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------

# Per-tenant default read RPS and write RPS. Tenants can override via the
# rate_limits table (Postgres advisory-lock gate).
DEFAULT_READS_PER_SECOND=100
DEFAULT_WRITES_PER_SECOND=10

# In-process token-bucket rate limiting (per tenant, per minute).
# RATE_LIMIT_ENABLED=true disables enforcement when set to false/0/no without
# requiring a redeployment.  Separate budgets for reads (GET/HEAD) and writes
# (POST/PUT/PATCH/DELETE).  In a multi-process deployment each worker process
# holds its own bucket state; effective limit across N workers is up to
# N × per_minute.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WRITE_PER_MINUTE=60
RATE_LIMIT_READ_PER_MINUTE=600

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------

# OTLP HTTP endpoint for trace export (e.g. Jaeger, Honeycomb, Tempo, OTel
# Collector). Leave unset to disable tracing.
# OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Service name used in OTel resource attributes.
SERVICE_NAME=registry

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# LOG_FORMAT controls log output: "json" for structured JSON to stdout (production
# default), "text" for human-readable plain text (local development).
LOG_FORMAT=json

# LOG_LEVEL is the root logger level. DEBUG surfaces SQLAlchemy queries and
# OpenTelemetry SDK internals — high volume; reserve for diagnosis.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Sync connectors
# -----------------------------------------------------------------------------

# Per-connector run timeout (seconds). Applies to the full connector
# coroutine including pagination.
CONNECTOR_RUN_TIMEOUT_S=300

# Webhook secrets — set at deployment time, not in this file. Settings
# checks these first; sync/webhook.py falls back to os.environ as a
# per-instance secret override (allows rotation without a settings reload).
# GITHUB_WEBHOOK_SECRET=<set-in-secret-store>
# GITLAB_WEBHOOK_SECRET=<set-in-secret-store>

# Per-connector credentials are resolved by a dynamic ref string at run
# time (sync/connector.py:resolve_credential), so they are NOT in Settings
# — set them in the deployment's secret store under the names the
# connector definitions request.

# -----------------------------------------------------------------------------
# Performance / SLO
# -----------------------------------------------------------------------------

# Slow-query warning threshold (milliseconds). Queries beyond this emit a
# WARNING log.
QUERY_LATENCY_WARN_MS=500.0

# Partition fan-out for the embeddings table (HASH-partitioned).
EMBEDDINGS_PARTITION_COUNT=8

# -----------------------------------------------------------------------------
# Closure refresh worker
# -----------------------------------------------------------------------------

# Maximum number of outbox rows processed concurrently per drain cycle.
# Each concurrent task holds one DB connection; keep below your connection
# pool capacity divided by the number of worker processes you run.
CLOSURE_REFRESH_CONCURRENCY=8
