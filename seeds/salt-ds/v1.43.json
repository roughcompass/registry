    {
      "name": "salt-button",
      "entity_type": "concept",
      "parent": "salt-design-system",
      "valid_from": "2025-09-15T00:00:00Z",
      "attributes": {
        "display_name": "Button",
        "category": "form-controls",
        "summary": "Standard, accent, and CTA buttons with focus-ring and disabled states.",
        "interface": {
          "package": "@salt-ds/core",
          "import_name": "Button",
          "props": [
            {"name": "disabled",             "type": "boolean",                                                  "required": false, "default": "false"},
            {"name": "focusableWhenDisabled","type": "boolean",                                                  "required": false, "default": "false"},
            {"name": "variant",             "type": "'primary' | 'secondary' | 'cta'",                          "required": false, "default": "'primary'", "deprecated": "Use appearance + sentiment instead"},
            {"name": "appearance",          "type": "'solid' | 'bordered' | 'transparent'",                     "required": false, "default": "'solid'"},
            {"name": "sentiment",           "type": "'accented' | 'neutral' | 'positive' | 'negative' | 'caution'", "required": false, "default": "'neutral'"},
            {"name": "loading",             "type": "boolean",                                                  "required": false, "default": "false"},
            {"name": "loadingAnnouncement", "type": "string",                                                   "required": false}
          ]
        }
      }
    },

    {
      "name": "salt-icon-button",
      "entity_type": "concept",
      "parent": "salt-design-system",
      "valid_from": "2025-09-15T00:00:00Z",
      "attributes": {
        "display_name": "IconButton",
        "category": "form-controls",
        "summary": "Icon-only button for compact toolbars and table actions.",
        "interface": {
          "package": "@salt-ds/core",
          "import_name": "Button",
          "notes": "Icon-only usage of Button: render a single Salt icon as children and add aria-label for accessibility.",
          "props": [
            {"name": "disabled",             "type": "boolean",                                                  "required": false, "default": "false"},
            {"name": "focusableWhenDisabled","type": "boolean",                                                  "required": false, "default": "false"},
            {"name": "appearance",          "type": "'solid' | 'bordered' | 'transparent'",                     "required": false, "default": "'transparent'"},
            {"name": "sentiment",           "type": "'accented' | 'neutral' | 'positive' | 'negative' | 'caution'", "required": false, "default": "'neutral'"},
            {"name": "aria-label",          "type": "string",                                                   "required": true}
          ]
        }
      }
    },

    {
