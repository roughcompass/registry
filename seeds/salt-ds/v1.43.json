        "interface": {
          "package": "@salt-ds/core",
          "import_name": "Input",
          "props": [
            {"name": "value",               "type": "string",                                 "required": false},
            {"name": "defaultValue",        "type": "string",                                 "required": false},
            {"name": "disabled",            "type": "boolean",                                "required": false, "default": "false"},
            {"name": "readOnly",            "type": "boolean",                                "required": false, "default": "false"},
            {"name": "placeholder",         "type": "string",                                 "required": false},
            {"name": "validationStatus",    "type": "'error' | 'warning' | 'success'",        "required": false},
            {"name": "variant",             "type": "'primary' | 'secondary'",                "required": false, "default": "'primary'"},
            {"name": "bordered",            "type": "boolean",                                "required": false, "default": "false"},
            {"name": "startAdornment",      "type": "ReactNode",                              "required": false},
            {"name": "endAdornment",        "type": "ReactNode",                              "required": false},
            {"name": "textAlign",           "type": "'left' | 'center' | 'right'",            "required": false, "default": "'left'"},
            {"name": "emptyReadOnlyMarker", "type": "string",                                 "required": false, "default": "'—'"},
            {"name": "inputProps",          "type": "Partial<InputHTMLAttributes<HTMLInputElement>>", "required": false},
            {"name": "inputRef",            "type": "Ref<HTMLInputElement>",                  "required": false}
          ]
        }
