    {
      "name": "salt-data-grid",
      "entity_type": "concept",
      "parent": "salt-design-system",
      "valid_from": "2025-09-15T00:00:00Z",
      "attributes": {
        "display_name": "DataGrid",
        "category": "data",
        "summary": "Virtualised, columnar grid with sort, group, and column pinning.",
        "interface": {
          "package": "@salt-ds/data-grid",
          "import_name": "Grid",
          "notes": "DataGrid is the @salt-ds/data-grid Grid component — a virtualised columnar grid built on top of the Salt design tokens.",
          "props": [
            {"name": "rowData",            "type": "T[]",                                     "required": true},
            {"name": "children",           "type": "ReactNode",                               "required": true,  "notes": "GridColumn or ColumnGroup children"},
            {"name": "rowKeyGetter",       "type": "(row: T, index: number) => string",        "required": false},
            {"name": "zebra",              "type": "boolean",                                 "required": false, "default": "false"},
            {"name": "hideHeader",         "type": "boolean",                                 "required": false, "default": "false"},
            {"name": "columnSeparators",   "type": "boolean",                                 "required": false, "default": "false"},
            {"name": "pinnedSeparators",   "type": "boolean",                                 "required": false, "default": "false"},
            {"name": "variant",            "type": "'primary' | 'secondary'",                 "required": false, "default": "'primary'"},
